# Required: OpenAI-compatible inference endpoint used by langextract
OPENAI_API_MODEL=mistral-small-vllm
OPENAI_API_BASE=http://127.0.0.1:8000/v1
OPENAI_API_KEY=replace-me

# Optional: prefer fast tokenizer path for large serving stacks (vLLM/TGI)
# HF_HOME=/data/cache/huggingface

# Optional (H100 / DGX Spark serving hint): endpoint can expose bigger context/model
# OPENAI_API_MODEL=your-h100-or-dgx-model-id
